{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pytest *)"
    ],
    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin master)",
      "Bash(git push -u origin main)",
      "Bash(git push -u origin master)",
      "Bash(git push --force origin master)",
      "Bash(git push --force-with-lease origin main)",
      "Bash(git push --force-with-lease origin master)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/user/ai-assistant/.claude/hooks/branch-policy.sh",
            "timeout": 10,
            "statusMessage": "Checking branch policy..."
          }
        ]
      }
    ]
  }
}
