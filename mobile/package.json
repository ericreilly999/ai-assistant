{
  "name": "ai-assistant-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchAll=false",
    "test:watch": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-expo|expo[^/]*|@expo|@react-native|react-native)/)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx"
    ]
  },
  "dependencies": {
    "expo": "~54.0.0",
    "expo-auth-session": "~7.0.10",
    "expo-crypto": "~15.0.8",
    "expo-secure-store": "~15.0.8",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "jest": "^29.5.0",
    "jest-expo": "~54.0.0",
    "typescript": "^5.8.2"
  }
}
