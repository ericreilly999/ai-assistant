{
  "name": "ai-assistant-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchAll=false",
    "test:watch": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterFramework": [
      "@testing-library/react-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(jest-expo|expo|@expo|expo-modules-core|expo-auth-session|expo-secure-store|expo-web-browser|expo-crypto|react-native|@react-native)/)"
    ],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx"]
  },
  "dependencies": {
    "expo": "~53.0.0",
    "expo-auth-session": "~6.1.0",
    "expo-crypto": "~14.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-web-browser": "~14.1.0",
    "react": "19.0.0",
    "react-native": "0.79.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^19.0.10",
    "jest": "^29.5.0",
    "jest-expo": "~53.0.0",
    "typescript": "^5.8.2"
  }
}
